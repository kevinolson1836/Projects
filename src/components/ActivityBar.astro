---
// Explorer + Work views; active state set by client via hash
---

<div class="activity-bar" id="activity-bar">
  <a href="#explorer" class="activity-bar-item active" id="activity-explorer" title="Explorer">
    <svg viewBox="0 0 24 24" width="24" height="24">
      <path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v5h5v11H6z"/>
    </svg>
  </a>
  <a href="#work" class="activity-bar-item" id="activity-work" title="Work">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="2" y="7" width="20" height="14" rx="2"/>
      <path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/>
    </svg>
  </a>
</div>

<script>
  function setActiveView() {
    const hash = window.location.hash.slice(1) || 'explorer';
    const explorer = document.getElementById('activity-explorer');
    const work = document.getElementById('activity-work');
    const sidebar = document.getElementById('sidebar-panels');
    if (explorer) explorer.classList.toggle('active', hash === 'explorer');
    if (work) work.classList.toggle('active', hash === 'work');
    if (sidebar) sidebar.dataset.active = hash;
  }
  setActiveView();
  window.addEventListener('hashchange', setActiveView);

  document.addEventListener('DOMContentLoaded', () => {
    const explorer = document.getElementById('activity-explorer');
    const work = document.getElementById('activity-work');
    const sidebar = document.getElementById('editor-sidebar');
    const expandTab = document.getElementById('sidebar-expand-tab');
    const STORAGE_KEY = 'kevins-lab-sidebar-collapsed';

    function setCollapsed(collapsed) {
      if (!sidebar) return;
      sidebar.classList.toggle('collapsed', collapsed);
      if (expandTab) expandTab.hidden = !collapsed;
      try {
        localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '');
      } catch (_) {}
    }

    function isCollapsed() {
      if (!sidebar) return false;
      try {
        return sidebar.classList.contains('collapsed') || localStorage.getItem(STORAGE_KEY) === '1';
      } catch (_) {
        return sidebar.classList.contains('collapsed');
      }
    }

    function handleActivityClick(targetView) {
      const currentHash = window.location.hash.slice(1) || 'explorer';
      const currentlyCollapsed = isCollapsed();

      if (currentHash === targetView) {
        setCollapsed(!currentlyCollapsed);
      } else if (currentlyCollapsed) {
        setCollapsed(false);
      }
    }

    explorer?.addEventListener('click', () => handleActivityClick('explorer'));
    work?.addEventListener('click', () => handleActivityClick('work'));
  });
</script>
