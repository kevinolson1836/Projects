---
// Inline script runs in browser; finds .embed-3d and mounts Three.js viewers for STL/OBJ/GLB/GLTF (Fusion 360 exports).
---

<div id="model-viewer-roots"></div>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { STLLoader } from 'three/addons/loaders/STLLoader.js';
  import { OBJLoader } from 'three/addons/loaders/OBJLoader.js';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll<HTMLElement>('.embed-3d');
    if (!containers.length) return;

    const stlLoader = new STLLoader();
    const objLoader = new OBJLoader();
    const gltfLoader = new GLTFLoader();

    function getExt(url: string): string {
      const path = url.split('?')[0];
      const m = path.match(/\.(stl|obj|glb|gltf)$/i);
      return m ? m[1].toLowerCase() : '';
    }

    function loadModel(
      url: string,
      ext: string
    ): Promise<THREE.Group | THREE.Mesh | THREE.BufferGeometry> {
      return new Promise((resolve, reject) => {
        if (ext === 'stl') {
          stlLoader.load(
            url,
            (geom) => resolve(geom),
            undefined,
            (e) => reject(e)
          );
        } else if (ext === 'obj') {
          objLoader.load(
            url,
            (group) => resolve(group),
            undefined,
            (e) => reject(e)
          );
        } else if (ext === 'glb' || ext === 'gltf') {
          gltfLoader.load(
            url,
            (gltf) => resolve(gltf.scene),
            undefined,
            (e) => reject(e)
          );
        } else {
          reject(new Error('Unsupported model format'));
        }
      });
    }

    containers.forEach((el) => {
      const src = el.getAttribute('data-src');
      const label = el.getAttribute('data-label') || 'Model';
      if (!src) return;

      const ext = getExt(src);
      if (!['stl', 'obj', 'glb', 'gltf'].includes(ext)) return;

      const wrap = document.createElement('div');
      wrap.className = 'embed-3d-wrap';
      const canvas = document.createElement('canvas');
      wrap.appendChild(canvas);
      el.appendChild(wrap);

      const width = el.offsetWidth || 640;
      const height = Math.min(360, Math.max(260, width * 0.5));

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x1e1e1e);
      const camera = new THREE.PerspectiveCamera(50, width / height, 0.1, 1000);
      camera.position.set(2, 2, 2);

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
      renderer.setSize(width, height);
      renderer.setPixelRatio(Math.min(2, window.devicePixelRatio));
      renderer.outputColorSpace = THREE.SRGBColorSpace;

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;

      const ambient = new THREE.AmbientLight(0xffffff, 0.6);
      scene.add(ambient);
      const dir = new THREE.DirectionalLight(0xffffff, 0.8);
      dir.position.set(2, 4, 3);
      scene.add(dir);

      const defaultMaterial = new THREE.MeshPhongMaterial({ color: 0x90a4ae, flatShading: true });

      loadModel(src, ext)
        .then((result) => {
          const root = result instanceof THREE.BufferGeometry
            ? new THREE.Mesh(result, defaultMaterial)
            : result as THREE.Object3D;
          if (root instanceof THREE.Mesh && !root.material) root.material = defaultMaterial;
          if (root instanceof THREE.Group) {
            root.traverse((child) => {
              if (child instanceof THREE.Mesh && !child.material) child.material = defaultMaterial;
            });
          }
          scene.add(root);
          const box = new THREE.Box3().setFromObject(root);
          const center = box.getCenter(new THREE.Vector3());
          const size = box.getSize(new THREE.Vector3());
          root.position.sub(center);
          const maxDim = Math.max(size.x, size.y, size.z);
          if (maxDim > 0) camera.position.multiplyScalar(maxDim * 0.8);
          controls.update();
        })
        .catch(() => {
          const msg = document.createElement('p');
          msg.className = 'embed-3d-error';
          msg.textContent = `Could not load model: ${label}`;
          wrap.appendChild(msg);
        });

      function animate() {
        requestAnimationFrame(animate);
        controls.update();
        renderer.render(scene, camera);
      }
      animate();

      const ro = new ResizeObserver(() => {
        const w = el.offsetWidth;
        const h = Math.min(360, Math.max(260, w * 0.5));
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        renderer.setSize(w, h);
      });
      ro.observe(el);
    });
  });
</script>
