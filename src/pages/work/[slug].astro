---
import EditorLayout from '../../layouts/EditorLayout.astro';
import { loadWork } from '../../lib/work';
import { renderMarkdown } from '../../lib/markdown';
import ModelViewerInit from '../../components/ModelViewerInit.astro';

export function getStaticPaths() {
  const work = loadWork();
  return work.map((w) => ({
    params: { slug: w.slug },
    props: { work: w },
  }));
}

const { work } = Astro.props;
const works = loadWork();
const workList = works.map((w) => ({ slug: w.slug, title: w.title }));

const notesHtml = renderMarkdown(work.notes, `/images/${work.slug}/`, work.slug);
---

<EditorLayout
  title={work.title}
  currentTab={`${work.slug}.md`}
  projects={workList}
  currentSlug={work.slug}
>
  <h1>{work.title}</h1>

  <p>
    <strong>Status:</strong> {work.status}<br />
    <strong>Progress:</strong> {work.progress}%
  </p>

  <h2>Build Log</h2>
  <Fragment set:html={notesHtml} />

  <ModelViewerInit />
</EditorLayout>
