---
import EditorLayout from '../../layouts/EditorLayout.astro';
import { loadWork } from '../../lib/work';
import { loadProjects } from '../../lib/projects';
import { renderMarkdown } from '../../lib/markdown';
import ModelViewerInit from '../../components/ModelViewerInit.astro';

const workEntries = loadWork();
const work = workEntries[0];

const projects = loadProjects();
const projectList = projects.map((p) => ({ slug: p.slug, title: p.title }));

const notesHtml = work ? renderMarkdown(work.notes, `/images/${work.slug}/`, work.slug) : '';
console.log(work.started);


function formatDate(date) {
  const d = new Date(date);
  const options = {year: 'numeric', month: 'short', day: 'numeric' };
  return d.toLocaleDateString('en-US', options);
}

function getWorkDuration(workDuration) {
  const start = new Date(workDuration.started);
  const end = workDuration.ended ? new Date(workDuration.ended) : new Date();

  let years = end.getFullYear() - start.getFullYear();
  let months = end.getMonth() - start.getMonth();
  let days = end.getDate() - start.getDate();

  // Adjust days
  if (days < 0) {
    const prevMonth = new Date(end.getFullYear(), end.getMonth(), 0);
    days += prevMonth.getDate();
    months--;
  }

  // Adjust months
  if (months < 0) {
    months += 12;
    years--;
  }

  return `${years}y ${months}m ${days}d`;
}

---

<EditorLayout
  title={work?.title ?? 'Work'}
  currentTab="work.md"
  projects={projectList}
  currentSlug={work?.slug}
>
  {work ? (
    <>
      <h1>{work.title}</h1>

      <p><strong>Status:</strong> {work.status}</p>
      <p><strong>Company:</strong> {work.company}</p>
      <p><strong>Started:</strong> {formatDate(work.started)}</p>
      {work.ended && <p><strong>Ended:</strong> {formatDate(work.ended)}</p>}
      <p><strong>Duration:</strong> {getWorkDuration(work)}</p>

      <br>
      <br>
      <Fragment set:html={notesHtml} />

      <ModelViewerInit />
    </>
  ) : (
    <p>No work found.</p>
  )}
</EditorLayout>