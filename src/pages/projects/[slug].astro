---
import EditorLayout from '../../layouts/EditorLayout.astro';
import { loadProjects } from '../../lib/projects';
import { renderMarkdown } from '../../lib/markdown';
import ModelViewerInit from '../../components/ModelViewerInit.astro';

export function getStaticPaths() {
  const projects = loadProjects();
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const projects = loadProjects();
const projectList = projects.map((p) => ({ slug: p.slug, title: p.title }));

const notesHtml = renderMarkdown(project.notes, `/images/${project.slug}/`, project.slug);
---

<EditorLayout
  title={project.title}
  currentTab={`${project.slug}.md`}
  projects={projectList}
  currentSlug={project.slug}
>
  <h1>{project.title}</h1>

  <p>
    <strong>Status:</strong> {project.status}{Number(project.progress) !== -1 && <><br /><strong>Progress:</strong> {project.progress}%</>}
  </p>

  <h2>Build Log</h2>
  <Fragment set:html={notesHtml} />

  <ModelViewerInit />
</EditorLayout>